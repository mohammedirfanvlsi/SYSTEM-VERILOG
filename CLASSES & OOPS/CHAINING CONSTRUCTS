module chaining_conctruct;
  
  class parent;
    
    int a;
    
    function new(int a);
      
      this.a = a;
      
      $display("PARENT CONSTRUCTOR IS CALLED IS % A =0d",a);
      
    endfunction
    
  endclass
  
  class child extends parent;
    
    int b;
    
    function new(int a,int b);
      
      super.new(a);
      
      this.b = b;
      
      $display("CHILD CONSTRUCTOR IS CALLED IS % B =0d",b);
      
    endfunction
    
  endclass
      
  initial begin
    
    child c1;
    
    c1 = new(50,7);
    
      $display("Final values: a = %0d, b = %0d", c1.a, c1.b);
  end
  
endmodule

/* OUTPUT 

# KERNEL: PARENT CONSTRUCTOR IS CALLED IS A =0d         50
# KERNEL: CHILD CONSTRUCTOR IS CALLED IS B =0d          7
# KERNEL: Final values: a = 50, b = 7 */
