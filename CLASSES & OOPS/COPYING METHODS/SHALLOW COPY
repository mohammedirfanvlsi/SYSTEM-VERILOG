module shallow_copy;
  
  class ex;
    
    int a;
    
    function new();
      
      a = 10;
      
    endfunction
    
    function int display();
      
      $display("THE VALUE OF A IS %0d",a);
      
    endfunction
  endclass
    
    initial begin
      
      ex p1,p2;
      
      p1 = new();
      
      $display("contents of p1 before changes");
      
      p1.display();
      
      p2 = new p1;
      
      $display("contents of p2 before changes");
      
      p2.display();
      
      p2.a = 57;
      
      $display("contents of p1 after changes");
      
      p1.display();
      
      $display("contents of p2 after changes");
      
      p2.display();
      
    end
endmodule

