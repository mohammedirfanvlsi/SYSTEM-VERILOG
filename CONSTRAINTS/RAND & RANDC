   class MyPacket;
      // A 4-bit variable can hold values from 0 to 15 (because 2^4 = 16 values).
      // 'rand' means it will pick a random number like rolling a dice.
      rand  bit [3:0] address;

      // A 2-bit variable can hold values 0, 1, 2, or 3.
      // 'randc' (random-cyclic) means it will shuffle through 0,1,2,3 without repeating
      // until it has used all of them.
      randc bit [1:0] id;

      // The Rule Block
      constraint limit_address {
        address < 10; // Rule: Even though address can hold up to 15, we restrict it to under 10.
      }
    endclass

    // 2. The Module to run and test it
    module test_basics;
      MyPacket pkt; // Create a handle for the class

      initial begin
        pkt = new(); // Create the actual object
        $display("--- STEP 1: BASICS ---");

        // We use a repeat loop to press the 'randomize' button 5 times.
        repeat(10) begin
          // HOW: if randomize is successful (returns 1), we print the values.
          if (pkt.randomize() == 1) begin
            // $display will print the values on the screen. %0d means "decimal number".
            $display("Address (rand): %0d | ID (randc): %0d", pkt.address, pkt.id);
          end
        end
      end
    endmodule
      
