module function_array;
  
  function int sum_array(int arr[]);
    
    int sum,i;
    
    sum = 0;
    
    for(i=0;i<5;i=i+1)
    
    sum +=  arr[i];
    
    return sum;
    
  endfunction
  
  initial begin
    
    int result,data[5];
    
    data = '{10,10,10,20,7};
    
    result  = sum_array(data);
    
    $display("the value of result is %0d",result);
    
  end
endmodule

